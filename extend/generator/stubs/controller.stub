{{ relationReadActions }}
    /**
     * 新增。
     * POST /admin/v1/{{ modulePlural }}
     */
    public function save(): Response
    {
        validate({{ ModuleName }}Validate::class)->scene('create')->check($this->request->post());

        ${{ moduleName }} = (new {{ ModuleName }}Service($this->app))->create($this->request->post());

        return $this->success(${{ moduleName }}, '新增成功');
    }

    /**
     * 更新。
     * PUT /admin/v1/{{ modulePlural }}/:id
     */
    public function update(int $id): Response
    {
        validate({{ ModuleName }}Validate::class)->scene('update')->check($this->request->param());

        ${{ moduleName }} = (new {{ ModuleName }}Service($this->app))->update($id, $this->request->param());

        return $this->success(${{ moduleName }}, '更新成功');
    }

    /**
     * 删除。
     * DELETE /admin/v1/{{ modulePlural }}/:id
     */
    public function delete(int $id): Response
