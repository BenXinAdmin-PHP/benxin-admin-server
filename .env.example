# BenXinAdmin 后端环境变量示例
# 复制为 .env 后按本地或生产实际填写。.env 已在 .gitignore，禁止提交真实密钥。

# ----- 应用 -----
# 生产安全默认 false（探针/测试 seeder 靠它守门，生产不暴露）；本地开发可改 true 开调试与探针
APP_DEBUG = false
# 多租户开关，默认单租户 false
APP_MULTI_TENANT = false
# C 端演示数据开关，默认 false（生产保持干净）。置 true 后执行 `php think seed:run -s DemoContentSeeder`
# 播种演示文章/分类，供小程序/H5 门面预览；DemoContentSeeder 默认守门跳过，不污染全量 seed:run。
DEMO_SEED_ENABLE = false
# 三方密钥 AES 加密入库用的密钥（参数配置 is_sensitive 项、支付/短信/OSS 密钥）。
# 必须 ≥32 字节随机串，生产务必改，勿提交真实值；可用 openssl rand -hex 32 生成
CONFIG_CRYPT_KEY =

# ----- 数据库 MySQL 8 -----
DB_TYPE = mysql
DB_HOST = 127.0.0.1
# 宿主机连容器 MySQL 端口；3308 避开本机原生 MySQL 的 3306 及其他占用的 3307。容器内部仍 3306。
DB_PORT = 3308
DB_NAME = benxin_admin
DB_USER = benxin
DB_PASS = benxin
DB_CHARSET = utf8mb4
DB_PREFIX = bx_
# 仅 docker-compose 初始化 root 用，应用不使用
DB_ROOT_PASS = root

# ----- 缓存 -----
# 默认 file 免依赖通用缓存。JWT 黑/白名单固定走下方 redis（Valkey）store，与此默认无关。
CACHE_DRIVER = file

# ----- JWT 双 guard（ADR-8：lcobucci/jwt + 自建 BxJwt，HS256，双 guard 独立 secret）-----
# 两个 secret 必须为 ≥32 字节随机串，禁止提交真实值；可用 openssl rand -hex 32 生成
JWT_ADMIN_SECRET =
JWT_API_SECRET =
# 签发者标识
JWT_ISS = BenXinAdmin
# 后台 admin guard access 有效期（秒），默认 2h
JWT_ACCESS_TTL = 7200
# 后台 admin guard refresh 有效期（秒），默认 14d
JWT_REFRESH_TTL = 1209600
# C 端 api guard 独立 TTL（M5-A）：登录态保持久些提升体验，access 2h / refresh 30d
JWT_API_ACCESS_TTL = 7200
JWT_API_REFRESH_TTL = 2592000

# ----- 超级管理员初始密码（仅首次 seed 用，首登后请立即在后台修改）-----
# 禁止提交真实值；seed 读取此值经 Argon2id 哈希入库，不硬编码进种子文件
SUPER_ADMIN_INIT_PWD =

# ----- Valkey，Redis 协议兼容 -----
REDIS_HOST = 127.0.0.1
# 宿主机连容器 Valkey 端口；6380 避开本机原生 Redis 的 6379。容器内部仍 6379。
REDIS_PORT = 6380
REDIS_PASSWORD =
REDIS_DB = 0
REDIS_PREFIX = bx:

# ----- 跨域 CORS -----
# 允许的前端来源，逗号分隔，全环境生效。开发环境 APP_DEBUG=true 时额外自动放行 localhost/127.0.0.1 任意端口。
# 生产环境务必在此列出真实前端域名，例如 https://admin.example.com,https://m.example.com
CORS_ALLOW_ORIGINS =

# ----- 多语言 -----
DEFAULT_LANG = zh-cn
