# BenXinAdmin 后端环境变量示例
# 复制为 .env 后按本地或生产实际填写。.env 已在 .gitignore，禁止提交真实密钥。

# ----- 应用 -----
APP_DEBUG = true
# 多租户开关，默认单租户 false
APP_MULTI_TENANT = false
# 三方密钥 AES 加密入库用的密钥，生产务必改为随机强密钥，勿提交真实值
CONFIG_CRYPT_KEY =

# ----- 数据库 MySQL 8 -----
DB_TYPE = mysql
DB_HOST = 127.0.0.1
# 宿主机连容器 MySQL 用此端口；改 3307 避开本机原生 MySQL 的 3306。容器内部仍 3306。
DB_PORT = 3307
DB_NAME = benxin_admin
DB_USER = benxin
DB_PASS = benxin
DB_CHARSET = utf8mb4
DB_PREFIX = bx_
# 仅 docker-compose 初始化 root 用，应用不使用
DB_ROOT_PASS = root

# ----- 缓存 -----
# M0 用 file 免依赖。M1 起 JWT 黑白名单需落 Valkey，届时改为 redis 并安装 ext-redis。
CACHE_DRIVER = file

# ----- Valkey，Redis 协议兼容 -----
REDIS_HOST = 127.0.0.1
# 宿主机连容器 Valkey 用此端口；改 6380 避开本机原生 Redis 的 6379。容器内部仍 6379。
REDIS_PORT = 6380
REDIS_PASSWORD =
REDIS_DB = 0
REDIS_PREFIX = bx:

# ----- 多语言 -----
DEFAULT_LANG = zh-cn
