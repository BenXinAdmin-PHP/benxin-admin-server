# BenXinAdmin 后端环境变量示例
# 复制为 .env 后按本地或生产实际填写。.env 已在 .gitignore，禁止提交真实密钥。

# ----- 应用 -----
APP_DEBUG = true
# 多租户开关，默认单租户 false
APP_MULTI_TENANT = false
# 三方密钥 AES 加密入库用的密钥，生产务必改为随机强密钥，勿提交真实值
CONFIG_CRYPT_KEY =

# ----- 数据库 MySQL 8 -----
DB_TYPE = mysql
DB_HOST = 127.0.0.1
# 宿主机连容器 MySQL 端口；3308 避开本机原生 MySQL 的 3306 及其他占用的 3307。容器内部仍 3306。
DB_PORT = 3308
DB_NAME = benxin_admin
DB_USER = benxin
DB_PASS = benxin
DB_CHARSET = utf8mb4
DB_PREFIX = bx_
# 仅 docker-compose 初始化 root 用，应用不使用
DB_ROOT_PASS = root

# ----- 缓存 -----
# M0 用 file 免依赖。M1 起 JWT 黑/白名单需落 Valkey，届时改 redis 并装 ext-redis。
CACHE_DRIVER = file

# ----- Valkey，Redis 协议兼容 -----
REDIS_HOST = 127.0.0.1
# 宿主机连容器 Valkey 端口；6380 避开本机原生 Redis 的 6379。容器内部仍 6379。
REDIS_PORT = 6380
REDIS_PASSWORD =
REDIS_DB = 0
REDIS_PREFIX = bx:

# ----- 跨域 CORS -----
# 允许的前端来源，逗号分隔，全环境生效。开发环境 APP_DEBUG=true 时额外自动放行 localhost/127.0.0.1 任意端口。
# 生产环境务必在此列出真实前端域名，例如 https://admin.example.com,https://m.example.com
CORS_ALLOW_ORIGINS =

# ----- 多语言 -----
DEFAULT_LANG = zh-cn
